@model GLMS.Models.ViewModels.CreateServiceRequestViewModel

<h2>Create Service Request</h2>

<form method="post">

    <div class="mb-3">
        <label>Contract</label>
        <select asp-for="ContractId" class="form-control">
            @foreach (var c in Model.Contracts)
            {
                <option value="@c.Id">
                    @c.ClientName (Contract @c.Id)
                </option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label>Description</label>
        <input asp-for="Description" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Amount</label>
        <input asp-for="Amount" class="form-control" />
    </div>

    <button class="btn btn-success">Submit</button>

</form>