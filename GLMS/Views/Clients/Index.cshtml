@model List<GLMS.Models.ViewModels.ClientViewModel>

<h2>Clients</h2>

<a class="btn btn-primary mb-3" href="/Clients/Create">
    + Create Client
</a>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Id</th>
            <th>Client Name</th>
            <th>Email</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var client in Model)
        {
            <tr>
                <td>@client.Id</td>
                <td>@client.Name</td>
                <td>@client.Email</td>
            </tr>
        }
    </tbody>
</table>